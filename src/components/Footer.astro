---
import { site } from '../data/site';
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <p class="kicker">THALCOR / quiet build mode</p>
      <p>Ideas become experiments. Experiments become proof. Proof becomes leverage.</p>
    </div>
    <a href={`mailto:${site.email}`}>{site.email}</a>
  </div>
</footer>
<style>
  .site-footer { border-top: 1px solid var(--color-line); margin-top: 5rem; padding: 2rem 0; }
  .footer-inner { display: flex; align-items: end; justify-content: space-between; gap: 1rem; }
  p { margin: .25rem 0 0; }
  a { color: var(--color-silver); text-decoration: none; border-bottom: 1px solid var(--color-accent); }
  @media (max-width: 760px) { .footer-inner { align-items: start; flex-direction: column; } }
</style>
