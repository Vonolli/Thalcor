---
interface Props { src: string; alt?: string; label?: string; }
const { src, alt = '', label = 'Media placeholder' } = Astro.props;
const isVideo = src?.match(/\.(mp4|webm|mov)$/i);
---
<figure class="media-block surface">
  <div class="label">{label}</div>
  {isVideo ? <video src={src} controls playsinline preload="metadata"></video> : <img src={src} alt={alt} loading="lazy" />}
  <figcaption>Swap this placeholder path for production images or video in `public/assets`.</figcaption>
</figure>
<style>
  .media-block { margin: 2rem 0 0; }
  .label { position: absolute; z-index: 2; top: 1rem; left: 1rem; padding: .45rem .65rem; border: 1px solid var(--color-line); background: rgba(5,7,11,.72); color: var(--color-accent); font-size: .66rem; letter-spacing: .16em; text-transform: uppercase; }
  img, video { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; filter: saturate(.78) contrast(1.08); }
  figcaption { margin: 0; padding: .8rem 1rem; border-top: 1px solid var(--color-line); color: var(--color-dim); font-size: .82rem; }
</style>
