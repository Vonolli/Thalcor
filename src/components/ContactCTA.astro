---
import { site } from '../data/site';
import Button from './Button.astro';
---
<section class="contact-cta container surface">
  <div>
    <p class="kicker">Join / invest</p>
    <h2>Bring capital, craft, manufacturing, engineering, or execution to a specific track.</h2>
    <p>Thalcor is built to attract aligned people around defined programs instead of vague networking.</p>
  </div>
  <Button href={`mailto:${site.email}`}>{site.email}</Button>
</section>
<style>
  .contact-cta { display: flex; align-items: end; justify-content: space-between; gap: 2rem; margin-top: 4rem; padding: clamp(1.25rem, 4vw, 2rem); }
  h2 { max-width: 840px; font-size: clamp(2rem, 5vw, 4.8rem); }
  p:not(.kicker) { max-width: 680px; }
  @media (max-width: 760px) { .contact-cta { align-items: start; flex-direction: column; } }
</style>
