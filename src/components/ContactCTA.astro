---
import { getSiteContent } from '../lib/content';

const site = await getSiteContent();
const contactCta = site.contactCta;
import Button from './Button.astro';
---
<section class="contact-cta container surface">
  <div>
    <p class="kicker">{contactCta.eyebrow}</p>
    <h2>{contactCta.heading}</h2>
    <p>{contactCta.text}</p>
  </div>
  <Button href={`mailto:${site.email}`}>{contactCta.buttonLabel}</Button>
</section>
<style>
  .contact-cta { display: flex; align-items: end; justify-content: space-between; gap: 2rem; margin-top: 5rem; padding: clamp(1.35rem, 4vw, 2.35rem); }
  h2 { max-width: 840px; font-size: clamp(2rem, 5vw, 4.8rem); }
  p:not(.kicker) { max-width: 680px; }
  @media (max-width: 760px) { .contact-cta { align-items: start; flex-direction: column; } }
</style>
