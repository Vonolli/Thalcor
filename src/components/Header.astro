---
import { navigation } from '../data/navigation';
import { site } from '../data/site';
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={`${site.name} home`}>
      <img src={site.brandLogo} alt="" width="34" height="34" />
      <span>{site.name}</span>
    </a>
    <nav aria-label="Primary navigation">
      {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>
<style>
  .site-header { position: sticky; top: 0; z-index: 20; border-bottom: 1px solid var(--color-line); background: rgba(251, 250, 246, 0.86); backdrop-filter: blur(18px); }
  .header-inner { display: flex; align-items: center; justify-content: space-between; min-height: 78px; gap: 1rem; }
  .brand { display: inline-flex; align-items: center; gap: .75rem; color: var(--color-text); text-decoration: none; font-weight: 800; letter-spacing: .22em; text-transform: uppercase; }
  .brand img { border: 1px solid var(--color-line); border-radius: 50%; background: #fff; padding: 3px; }
  nav { display: flex; align-items: center; gap: .2rem; flex-wrap: wrap; justify-content: flex-end; }
  nav a { border-radius: 999px; padding: .68rem .78rem; color: var(--color-muted); font-size: .72rem; font-weight: 750; letter-spacing: .13em; text-decoration: none; text-transform: uppercase; transition: color .2s ease, background .2s ease; }
  nav a:hover { color: var(--color-text); background: var(--color-accent-soft); }
  @media (max-width: 700px) {
    .header-inner { align-items: flex-start; flex-direction: column; padding: .85rem 0; }
    nav { justify-content: flex-start; }
    nav a { padding-left: 0; }
  }
</style>
