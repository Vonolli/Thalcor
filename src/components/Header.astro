---
import { getSiteContent } from '../lib/content';
import Wordmark from './Wordmark.astro';

const site = await getSiteContent();
const navigation = site.navigation;
const contact = site.contactButton ?? { label: 'CONTACT US', url: '/contact/' };
---
<header class="site-header">
  <div class="container header-shell">
    <a class="brand" href="/" aria-label={`${site.name} home`}>
      <Wordmark small />
    </a>
    <button class="menu-button" type="button" aria-controls="primary-nav" aria-expanded="false">Menu</button>
    <nav id="primary-nav" aria-label="Primary navigation">
      <div class="nav-links">
        {navigation.map((item) => <a href={item.url}>{item.label}</a>)}
      </div>
      <a class="contact-link" href={contact.url}>{contact.label}</a>
    </nav>
  </div>
</header>
<script>
  const button = document.querySelector('.menu-button');
  const nav = document.querySelector('#primary-nav');
  button?.addEventListener('click', () => {
    const expanded = button.getAttribute('aria-expanded') === 'true';
    button.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('is-open', !expanded);
  });
</script>
