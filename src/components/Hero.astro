---
import GoldDivider from './GoldDivider.astro';
import Wordmark from './Wordmark.astro';
interface Props { hero: { title: string; subtitle: string; body: string; }; }
const { hero } = Astro.props;
---
<section class="home-hero" aria-labelledby="hero-title">
  <div class="container home-hero__inner">
    <h1 id="hero-title"><Wordmark text={hero.title} /></h1>
    <p class="home-hero__subtitle">{hero.subtitle}</p>
    <GoldDivider />
    <p class="home-hero__body">{hero.body}</p>
  </div>
</section>
