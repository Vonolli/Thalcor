---
import Button from './Button.astro';
import { homepage } from '../data/site';
---
<section class="hero container" aria-labelledby="hero-title">
  <div class="hero-copy">
    <p class="kicker">{homepage.eyebrow}</p>
    <h1 id="hero-title">{homepage.headline}</h1>
    <p class="subheadline">{homepage.subheadline}</p>
    <p class="supporting">{homepage.supporting}</p>
    <div class="actions">
      <Button href={homepage.primaryActionUrl}>{homepage.primaryActionLabel}</Button>
      <Button href={homepage.secondaryActionUrl} variant="ghost">{homepage.secondaryActionLabel}</Button>
    </div>
  </div>
  <aside class="surface telemetry" aria-label="Studio telemetry">
    <p class="kicker">{homepage.telemetryEyebrow}</p>
    <dl>
      {homepage.telemetry.map((item) => <div><dt>{item.label}</dt><dd>{item.value}</dd></div>)}
    </dl>
  </aside>
</section>
<style>
  .hero { position: relative; display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: 1.5rem; align-items: end; min-height: calc(100svh - 76px); padding: 6.5rem 0 4.75rem; }
  .hero::before { content: ''; position: absolute; right: 18%; top: 20%; width: 38vw; height: 38vw; border-radius: 50%; background: radial-gradient(circle, rgba(127,199,255,.16), transparent 62%); filter: blur(10px); animation: pulse 8s ease-in-out infinite alternate; pointer-events: none; }
  .hero-copy { position: relative; max-width: 1000px; z-index: 1; }
  h1 { text-shadow: 0 0 44px rgba(127,199,255,.14); }
  .subheadline { max-width: 860px; margin: 1rem 0 0; color: var(--color-silver); font-size: clamp(1.55rem, 3vw, 2.65rem); line-height: 1.14; letter-spacing: -.025em; }
  .supporting { max-width: 760px; color: var(--color-muted); font-size: clamp(1rem, 1.6vw, 1.2rem); }
  .actions { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 1.7rem; }
  .telemetry { padding: 1.1rem; }
  dl { display: grid; gap: .85rem; margin: 0; }
  dl div { border-top: 1px solid var(--color-line); padding-top: .78rem; }
  dt { color: var(--color-dim); font-size: .68rem; letter-spacing: .16em; text-transform: uppercase; }
  dd { margin: .25rem 0 0; color: var(--color-text); font-weight: 750; }
  @keyframes pulse { from { opacity: .35; transform: translateY(0); } to { opacity: .8; transform: translateY(18px); } }
  @media (max-width: 920px) { .hero { grid-template-columns: 1fr; min-height: auto; padding-top: 4.5rem; } }
</style>
