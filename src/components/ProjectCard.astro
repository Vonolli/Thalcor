---
interface Props { project: any; }
const { project } = Astro.props;
const projectSlug = project.id.replace(/\.md$/, '');
---
<a class="project-card" href={`/projects/${projectSlug}/`}>
  <div class="media">
    <img src={project.data.previewImage} alt={`${project.data.title} preview placeholder`} loading="lazy" />
  </div>
  <div class="content">
    <p class="eyebrow">{project.data.category}</p>
    <h3>{project.data.title}</h3>
    <p class="tagline">{project.data.tagline}</p>
    <div class="foot">
      <span>{project.data.status}</span>
      <span>{project.data.featured ? 'Current Project' : 'Lab Project'}</span>
    </div>
  </div>
</a>
<style>
  .project-card {
    position: relative;
    display: grid;
    min-height: 470px;
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, .74);
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    transition: background .25s ease, transform .25s ease, box-shadow .25s ease;
  }
  .project-card:hover { z-index: 1; background: #fff; transform: translateY(-4px); box-shadow: 0 24px 60px rgba(60, 64, 67, .16); }
  .media { min-height: 235px; overflow: hidden; background: #ece8dc; }
  img { width: 100%; height: 100%; object-fit: cover; opacity: .9; filter: saturate(.92) contrast(1.02); transition: transform .5s ease, opacity .3s ease; }
  .project-card:hover img { transform: scale(1.045); opacity: 1; }
  .content { display: grid; align-content: start; gap: .72rem; padding: clamp(1.1rem, 2.5vw, 1.7rem); }
  .eyebrow { margin: 0; color: var(--color-accent); font-size: .68rem; font-weight: 850; letter-spacing: .16em; text-transform: uppercase; }
  h3 { font-family: var(--font-sans); font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 500; letter-spacing: -.035em; line-height: .98; }
  .tagline { max-width: 32rem; margin: 0; color: var(--color-silver); font-size: 1.02rem; line-height: 1.55; }
  .foot { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: .4rem; color: var(--color-muted); font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
  .foot span { display: inline-flex; align-items: center; min-height: 2rem; border: 1px solid var(--color-line); border-radius: 999px; padding: .32rem .66rem; background: rgba(247,245,239,.7); }
  @media (max-width: 660px) {
    .project-card { min-height: auto; }
    .media { min-height: 200px; }
  }
</style>
