---
interface Props { project: any; }
const { project } = Astro.props;
const projectSlug = project.id.replace(/\.md$/, '');
---
<a class="project-card" href={`/projects/${projectSlug}/`}>
  <div class="media">
    <img src={project.data.previewImage} alt={`${project.data.title} project preview artwork`} loading="lazy" />
  </div>
  <div class="content">
    <p class="eyebrow">{project.data.category}</p>
    <h3>{project.data.title}</h3>
    <p class="tagline">{project.data.tagline}</p>
    <div class="foot">
      <span>{project.data.status}</span>
      <span>{project.data.featured ? 'Current Project' : 'Lab Project'}</span>
    </div>
  </div>
</a>
<style>
  .project-card {
    position: relative;
    display: grid;
    min-height: 500px;
    color: inherit;
    text-decoration: none;
    background: linear-gradient(160deg, rgba(13,20,32,.72), rgba(5,8,14,.88));
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    overflow: hidden;
    transition: background .25s ease, transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  }
  .project-card::after { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 70% 20%, rgba(127,199,255,.14), transparent 34%); opacity: 0; transition: opacity .25s ease; pointer-events: none; }
  .project-card:hover { z-index: 1; background: linear-gradient(160deg, rgba(18,28,43,.9), rgba(7,10,17,.96)); transform: translateY(-5px); box-shadow: 0 28px 80px rgba(0,0,0,.42), 0 0 34px rgba(127,199,255,.12); border-color: var(--color-line-strong); }
  .project-card:hover::after { opacity: 1; }
  .media { min-height: 250px; overflow: hidden; background: #080c13; }
  img { width: 100%; height: 100%; object-fit: cover; opacity: .78; filter: saturate(.82) contrast(1.08) brightness(.82); transition: transform .7s ease, opacity .3s ease, filter .3s ease; }
  .project-card:hover img { transform: scale(1.055); opacity: .98; filter: saturate(.98) contrast(1.08) brightness(.98); }
  .content { position: relative; z-index: 1; display: grid; align-content: start; gap: .76rem; padding: clamp(1.15rem, 2.5vw, 1.8rem); }
  .eyebrow { margin: 0; color: var(--color-accent); font-size: .68rem; font-weight: 850; letter-spacing: .17em; text-transform: uppercase; }
  h3 { font-family: var(--font-sans); font-size: clamp(1.9rem, 4vw, 3.2rem); font-weight: 520; letter-spacing: -.045em; line-height: .96; }
  .tagline { max-width: 34rem; margin: 0; color: var(--color-silver); font-size: 1.02rem; line-height: 1.55; }
  .foot { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: .4rem; color: var(--color-muted); font-size: .7rem; font-weight: 820; letter-spacing: .12em; text-transform: uppercase; }
  .foot span { display: inline-flex; align-items: center; min-height: 2rem; border: 1px solid var(--color-line); border-radius: 999px; padding: .32rem .66rem; background: rgba(255,255,255,.035); }
  @media (max-width: 660px) { .project-card { min-height: auto; } .media { min-height: 210px; } }
</style>
