---
interface Props { href: string; variant?: 'solid' | 'ghost'; }
const { href, variant = 'solid' } = Astro.props;
---
<a class:list={['button', variant]} href={href}><slot /></a>
<style>
  .button { display: inline-flex; align-items: center; justify-content: center; min-height: 44px; padding: .8rem 1rem; border: 1px solid var(--color-line-strong); border-radius: 999px; color: var(--color-text); font-size: .76rem; font-weight: 800; letter-spacing: .14em; text-decoration: none; text-transform: uppercase; transition: transform .22s ease, border-color .22s ease, box-shadow .22s ease, background .22s ease; }
  .button.solid { background: linear-gradient(135deg, rgba(127,180,223,.28), rgba(199,209,220,.08)); box-shadow: 0 0 34px rgba(127, 180, 223, .12); }
  .button.ghost { background: rgba(8, 13, 20, .58); }
  .button:hover { transform: translateY(-2px); border-color: rgba(127,180,223,.72); box-shadow: 0 18px 36px rgba(0,0,0,.36), 0 0 30px rgba(127,180,223,.15); }
</style>
