---
interface Props { href: string; variant?: 'solid' | 'ghost'; }
const { href, variant = 'solid' } = Astro.props;
---
<a class:list={['button', variant]} href={href}><slot /></a>
<style>
  .button { display: inline-flex; align-items: center; justify-content: center; min-height: 46px; padding: .84rem 1.08rem; border: 1px solid var(--color-line-strong); border-radius: 999px; color: var(--color-text); font-size: .74rem; font-weight: 850; letter-spacing: .15em; text-decoration: none; text-transform: uppercase; transition: transform .22s ease, border-color .22s ease, box-shadow .22s ease, background .22s ease; }
  .button.solid { background: linear-gradient(135deg, rgba(127,199,255,.22), rgba(255,255,255,.07)); box-shadow: 0 14px 34px rgba(0,0,0,.24), 0 0 26px rgba(127,199,255,.1); }
  .button.ghost { background: rgba(255, 255, 255, .035); }
  .button:hover { transform: translateY(-2px); border-color: rgba(127,199,255,.72); box-shadow: 0 18px 42px rgba(0,0,0,.32), 0 0 30px rgba(127,199,255,.16); }
</style>
