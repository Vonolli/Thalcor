---
import GoldDivider from './GoldDivider.astro';
import Wordmark from './Wordmark.astro';
import { getSiteContent } from '../lib/content';
const { text = '' } = Astro.props;
const site = await getSiteContent();
const footerNav = site.navigation ?? [];
---
<section class="footer-horizon" aria-label="Thalcor horizon">
  <GoldDivider />
  <div class="footer-horizon__mark" aria-hidden="true">T</div>
  <Wordmark small />
  {text && <p>{text}</p>}
  <nav class="footer-horizon__nav" aria-label="Footer navigation">
    {footerNav.map((item) => <a href={item.url}>{item.label}</a>)}
  </nav>
</section>
