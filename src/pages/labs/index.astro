---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import ContactCTA from '../../components/ContactCTA.astro';
---
<BaseLayout title="Labs" description="THALCOR Labs contains experimental concepts, prototypes, frameworks, and internal systems." canonical="/labs/">
  <Section eyebrow="THALCOR Labs" title="A controlled environment for unstable ideas." intro="Labs is where experimental concepts, prototypes, frameworks, and internal systems are shaped before they are public enough to become projects.">
    <div class="grid grid-3">
      <article class="surface lab-card"><h3>Concepts</h3><p>Raw ideas are captured, named, constrained, and tested for strategic gravity.</p></article>
      <article class="surface lab-card"><h3>Prototypes</h3><p>Interfaces, renders, formulas, videos, models, field notes, and small technical systems prove what words cannot.</p></article>
      <article class="surface lab-card"><h3>Frameworks</h3><p>Internal systems turn repeated discoveries into leverage for future ventures and creative operations.</p></article>
    </div>
  </Section>
  <ContactCTA />
</BaseLayout>
<style>.lab-card { padding: 1.1rem; }</style>
