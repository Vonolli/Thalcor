---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import ContactCTA from '../../components/ContactCTA.astro';
---
<BaseLayout title="Research" description="THALCOR research briefs turn raw thinking into readable signals: market logic, technical notes, opportunity maps, and founder analysis." canonical="/research/">
  <Section eyebrow="Research briefs" title="Readable signals for markets, technologies, and opportunity maps." intro="Research briefs turn raw thinking into readable signals: market logic, technical notes, opportunity maps, first-principles breakdowns, and founder analysis.">
    <div class="brief-shell surface">
      <p class="kicker">Brief format</p>
      <h3>From vague thesis to usable decision document.</h3>
      <ul>
        <li>Why the project matters now.</li>
        <li>What has to be true technically, commercially, and operationally.</li>
        <li>Where proof can be created with the least wasted motion.</li>
        <li>Who might build, buy, fund, partner, or manufacture it.</li>
      </ul>
    </div>
  </Section>
  <ContactCTA />
</BaseLayout>
<style>
  .brief-shell { padding: 1.25rem; max-width: 860px; }
  .brief-shell h3 { margin-top: 2rem; }
  .brief-shell li { color: #b9c4cf; line-height: 1.8; }
</style>
