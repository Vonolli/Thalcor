---
import BaseLayout from '../layouts/BaseLayout.astro';
import AtmosphericBackground from '../components/AtmosphericBackground.astro';
import Hero from '../components/Hero.astro';
import MissionCategoryPanel from '../components/MissionCategoryPanel.astro';
import FooterHorizon from '../components/FooterHorizon.astro';
import { getHomepageContent, getMissionsContent } from '../lib/content';

const homepage = await getHomepageContent();
const missions = await getMissionsContent();
const categoryOrder = new Map(homepage.featuredCategories.map((id, index) => [id, index]));
const categories = missions.categories
  .filter((category) => category.visible && (categoryOrder.size === 0 || categoryOrder.has(category.id)))
  .sort((a, b) => (categoryOrder.get(a.id) ?? a.order) - (categoryOrder.get(b.id) ?? b.order));
---
<BaseLayout title={homepage.seoTitle} description={homepage.seoDescription} image={homepage.hero.backgroundImage} hideFooter>
  <AtmosphericBackground heroImage={homepage.hero.backgroundImage} horizonImage={homepage.footer.horizonImage} />
  <Hero hero={homepage.hero} />
  <div class="container mission-stack" aria-label="Mission categories">
    {categories.map((category) => <MissionCategoryPanel category={category} />)}
  </div>
  <FooterHorizon text={homepage.footer.text} />
</BaseLayout>
