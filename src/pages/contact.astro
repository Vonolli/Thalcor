---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site';
---
<BaseLayout title="Contact" description="Specific THALCOR collaboration, investment, builder, manufacturing, and creative partnership inquiries." canonical="/contact/">
  <Section eyebrow="Contact" title="Open a channel around a specific program." intro="Reach out when there is a focused collaboration, investment conversation, contractor capability, manufacturing path, or creative partnership worth discussing.">
    <div class="contact-panel surface">
      <div>
        <h3>Public channel</h3>
        <p>Include the program area that interests you, what you can contribute, and what kind of proof or partnership you want to discuss.</p>
      </div>
      <Button href={`mailto:${site.email}`}>{site.email}</Button>
    </div>
  </Section>
</BaseLayout>
<style>
  .contact-panel { display: flex; align-items: center; justify-content: space-between; gap: 2rem; padding: clamp(1.2rem, 4vw, 2rem); }
  .contact-panel p { max-width: 620px; }
  @media (max-width: 760px) { .contact-panel { align-items: flex-start; flex-direction: column; } }
</style>
