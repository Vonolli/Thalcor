---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import { contactPage, site } from '../data/site';
---
<BaseLayout title={contactPage.title} description={contactPage.description} canonical="/contact/">
  <Section eyebrow={contactPage.eyebrow} title={contactPage.heading} intro={contactPage.intro}>
    <div class="contact-panel surface">
      <div>
        <h3>{contactPage.panelTitle}</h3>
        <p>{contactPage.panelText}</p>
      </div>
      <Button href={`mailto:${site.email}`}>{site.email}</Button>
    </div>
  </Section>
</BaseLayout>
<style>
  .contact-panel { display: flex; align-items: center; justify-content: space-between; gap: 2rem; padding: clamp(1.2rem, 4vw, 2rem); }
  .contact-panel p { max-width: 620px; }
  @media (max-width: 760px) { .contact-panel { align-items: flex-start; flex-direction: column; } }
</style>
