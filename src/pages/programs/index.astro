---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { programCategories } from '../../data/programs';
---
<BaseLayout title="Programs" description="THALCOR programs across intelligence systems, future hardware, consumer brands, interactive worlds, creative IP, built environment, and venture infrastructure." canonical="/programs/">
  <Section eyebrow="Programs" title="Seven organized domains for experimental companies, systems, products, and worlds." intro="Each program sits inside a category with a clear thesis. The point is not to show every idea; it is to show where Thalcor is building proof.">
    <div class="program-nav" aria-label="Program categories">
      {programCategories.map((category) => <a href={`#${category.slug}`}>{category.title}</a>)}
    </div>
  </Section>

  {programCategories.map((category, categoryIndex) => (
    <section class="container category-section" id={category.slug}>
      <div class="category-head">
        <p class="kicker">{String(categoryIndex + 1).padStart(2, '0')}</p>
        <h2>{category.title}</h2>
        <p>{category.thesis}</p>
      </div>
      <div class="program-grid">
        {category.programs.map((program) => (
          <article class="surface program-card">
            <div class="program-meta">
              <p class="kicker">{program.label}</p>
            </div>
            <h3>{program.name}</h3>
            <p class="description">{program.description}</p>
            <p class="quote">“{program.copy}”</p>
          </article>
        ))}
      </div>
    </section>
  ))}

  <ContactCTA />
</BaseLayout>
<style>
  .program-nav { display: flex; flex-wrap: wrap; gap: .65rem; }
  .program-nav a { border: 1px solid var(--color-line); border-radius: 999px; padding: .58rem .78rem; color: var(--color-silver); background: rgba(8, 13, 20, .58); font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-decoration: none; text-transform: uppercase; }
  .program-nav a:hover { border-color: var(--color-line-strong); background: var(--color-accent-soft); color: var(--color-text); }
  .category-section { scroll-margin-top: 100px; padding-top: 4.5rem; }
  .category-head { display: grid; gap: .75rem; max-width: 860px; margin-bottom: 1.3rem; }
  .category-head p:not(.kicker) { margin: 0; font-size: 1.05rem; }
  .program-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
  .program-card { display: grid; align-content: start; min-height: 280px; padding: 1.15rem; }
  .program-meta { min-height: 2.4rem; }
  .program-card h3 { margin-top: 1.2rem; }
  .description { margin-bottom: 0; }
  .quote { border-top: 1px solid var(--color-line); margin: 1rem 0 0; padding-top: 1rem; color: var(--color-silver); font-size: 1.02rem; }
  @media (max-width: 820px) { .program-grid { grid-template-columns: 1fr; } }
</style>
