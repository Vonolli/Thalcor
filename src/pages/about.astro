---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About Thalcor" description="About Thalcor, an independent AI research and development lab." canonical="/about/">
  <section class="container product-hero">
    <p class="kicker">About Thalcor</p>
    <h1>Independent AI research for complex futures.</h1>
    <p class="home-hero__body">Thalcor builds predictive systems, simulation environments, and intelligent software to help humanity better understand high-consequence problems before they unfold.</p>
  </section>
  <section class="container landing-grid">
    <article class="surface feature-card"><p class="kicker">Focus</p><h2>Prediction, simulation, intelligence.</h2><p>We work on tools that model changing environments, expose risk, and convert research prototypes into usable systems.</p></article>
    <article class="surface feature-card"><p class="kicker">Operating mode</p><h2>Simple, rigorous, artifact-led.</h2><p>Thalcor prioritizes prototypes, demos, datasets, technical notes, and research updates over broad claims.</p></article>
  </section>
</BaseLayout>
