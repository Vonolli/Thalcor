---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
import { site } from '../../data/site';
---
<BaseLayout title="Join / Invest" description="Express interest in specific THALCOR projects as an investor, builder, designer, engineer, manufacturer, operator, or collaborator." canonical="/join-invest/">
  <Section eyebrow="Investor / Talent Portal" title="Capital, skill, and aligned people around specific projects." intro="Thalcor is built to attract investors, builders, designers, engineers, manufacturers, operators, and collaborators around defined programs instead of vague networking.">
    <div class="surface join-card">
      <p class="kicker">Open a channel</p>
      <h3>Tell Thalcor what you can help build, fund, manufacture, design, or operate.</h3>
      <p>Use the contact link with your background, the program area that interests you, and the type of proof or partnership you want to discuss.</p>
      <Button href={`mailto:${site.email}`}>Contact {site.email}</Button>
    </div>
  </Section>
</BaseLayout>
<style>
  .join-card { display: grid; gap: 1rem; max-width: 860px; padding: 1.25rem; }
  .join-card h3 { margin-top: 2rem; }
  .join-card p:not(.kicker) { max-width: 680px; }
</style>
