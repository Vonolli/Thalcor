---
import BaseLayout from './BaseLayout.astro';
import MediaBlock from '../components/MediaBlock.astro';
import Button from '../components/Button.astro';

const { project } = Astro.props;
const projectSlug = project.id.replace(/\.md$/, '');
const { Content } = await project.render();
const heroMedia = project.data.heroVideo || project.data.heroImage;
const supportingMedia = [
  { label: 'Project video', href: project.data.videoPath },
  { label: 'Project document', href: project.data.documentPath },
].filter((item) => item.href);
---
<BaseLayout
  title={project.data.title}
  description={project.data.tagline}
  image={project.data.previewImage || project.data.heroImage}
  canonical={`/projects/${projectSlug}/`}
>
  <article class="project-detail container">
    <p class="kicker">Project dossier / {project.data.status}</p>
    <div class="title-row">
      {project.data.logoImage && <img src={project.data.logoImage} alt={`${project.data.title} logo`} class="project-logo" loading="lazy" />}
      <h1>{project.data.title}</h1>
    </div>
    <p class="tagline">{project.data.tagline}</p>

    <div class="meta-grid" aria-label="Project metadata">
      <div><span>Status</span><strong>{project.data.status}</strong></div>
      <div><span>Category</span><strong>{project.data.category}</strong></div>
      <div><span>Clearance</span><strong>{project.data.featured ? 'Featured' : 'Archive'}</strong></div>
    </div>

    <MediaBlock src={heroMedia} alt={`${project.data.title} hero media`} label="Hero media" />

    <div class="body-grid">
      <aside class="surface project-aside">
        <p class="kicker">File notes</p>
        <p>Update this project through Pages CMS or by editing its Markdown file. Images, logos, videos, and documents should live in `public/assets` and be referenced with `/assets/...` paths.</p>
        {project.data.externalUrl && <Button href={project.data.externalUrl} variant="ghost">External signal</Button>}
        {supportingMedia.length > 0 && (
          <ul class="asset-links">
            {supportingMedia.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        )}
      </aside>
      <div class="prose">
        <Content />
      </div>
    </div>

    <Button href="/projects/" variant="ghost">Back to projects</Button>
  </article>
</BaseLayout>

<style>
  .project-detail { padding: 5.5rem 0 4rem; }
  .title-row { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; }
  .project-logo { width: clamp(52px, 10vw, 92px); height: clamp(52px, 10vw, 92px); object-fit: contain; }
  h1 { font-size: clamp(4rem, 13vw, 9rem); }
  .tagline { max-width: 760px; margin: 1.2rem 0 1.8rem; color: var(--color-silver); font-size: clamp(1.15rem, 2vw, 1.55rem); }
  .meta-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .85rem; margin: 2rem 0; }
  .meta-grid div, .project-aside { padding: 1rem; }
  .meta-grid div { border: 1px solid var(--color-line); background: rgba(255, 255, 255, 0.78); border-radius: var(--radius-md); }
  .meta-grid span { display: block; color: var(--color-dim); font-size: .7rem; letter-spacing: .16em; text-transform: uppercase; }
  .meta-grid strong { display: block; margin-top: .35rem; color: var(--color-text); text-transform: uppercase; }
  .body-grid { display: grid; grid-template-columns: minmax(220px, .36fr) 1fr; gap: 2rem; align-items: start; margin: 3rem 0; }
  .project-aside { position: sticky; top: 6rem; }
  .asset-links { display: grid; gap: .5rem; margin: 1rem 0 0; padding-left: 1rem; }
  .asset-links a { color: var(--color-accent); font-weight: 800; text-transform: uppercase; letter-spacing: .08em; font-size: .74rem; }
  @media (max-width: 860px) {
    .project-detail { padding-top: 3.5rem; }
    .meta-grid, .body-grid { grid-template-columns: 1fr; }
    .project-aside { position: static; }
  }
</style>
